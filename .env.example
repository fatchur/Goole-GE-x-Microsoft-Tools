# Salin file ini jadi ".env" lalu isi dengan nilai kamu sendiri.
# JANGAN commit file ".env" (isi rahasia) ke git.

PORT=8080

# --- Microsoft Entra ID (App Registration "gemini-enterprise-sso-test") ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=isi-dengan-client-secret-dari-azure
ENTRA_REDIRECT_URI=http://localhost:8080/auth/callback

# --- GCP Workforce Identity Federation (Bagian 2-3 dokumentasi) ---
GCP_WORKFORCE_POOL_ID=cngpt-entra-pool
GCP_WORKFORCE_PROVIDER_ID=entra-oidc-provider

# --- Gemini Enterprise ---
GCP_PROJECT_ID=ge-test-123
GEMINI_APP_ID=gemini-enterprise-1783673478762
GEMINI_LOCATION=global

# --- Outlook Connector (Optional - untuk akses email/calendar via connector) ---
# Format: outlook-federated-connector_TIMESTAMP
# Atau format lengkap: collections/outlook-federated-connector_TIMESTAMP/dataConnector
# Kalau diisi, request akan include dataStoreSpecs untuk query connector data
OUTLOOK_CONNECTOR_ID=outlook-federated-connector_1783678287149

# --- Microsoft Connector OAuth (untuk custom connector authorization - currently disabled) ---
# Note: acquireAndStoreRefreshToken endpoint tidak tersedia untuk public API
# Gunakan manual authorization via Gemini WebApp sebagai gantinya
CONNECTOR_CLIENT_ID=
CONNECTOR_CLIENT_SECRET=
CONNECTOR_REDIRECT_URI=http://localhost:8080/auth/connector/callback

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Cookie ---
# Set "true" hanya kalau backend sudah jalan di HTTPS (production).
COOKIE_SECURE=false
